# ─── GitHub ────────────────────────────────────────────────────────────────────
# Your GitHub username
GH_USER=your-github-username

# GitHub organization name. Use your username for personal repos.
GH_ORG=your-github-org

# ─── Jira / Atlassian (used for manual JQL prompts with Claude / Copilot) ─────
# Your Atlassian Cloud site URL (e.g. https://your-org.atlassian.net)
JIRA_SITE_URL=https://your-org.atlassian.net

# Jira project key to filter issues (e.g. ENG, PROJ, PLATFORM)
JIRA_PROJECT=YOUR_PROJECT_KEY

# Your Jira account ID — find it in your Atlassian profile URL
# (e.g. https://your-org.atlassian.net/jira/people/712020:abc123...)
JIRA_ACCOUNT_ID=your-jira-account-id
